---
// src/components/GroupCard.astro
// Componentă reutilizabilă pentru afișarea unui singur grup/canal.

export interface Props {
  group: {
    id: number;
    name: string;
    username: string | null;
    platform: string;
    type: string | null;
    members: number | null;
    description: string | null;
    verified: boolean;
    scam: boolean;
    fake: boolean;
    url: string | null;
    avatar: string | null;
  };
}

const { group } = Astro.props;

// Inițiale pentru avatar placeholder, dacă nu există imagine
const initials = group.name
  ?.split(" ")
  .map((w) => w[0])
  .slice(0, 2)
  .join("")
  .toUpperCase();

const baseUrl = import.meta.env.BASE_URL;

function resolveAvatarSrc(avatar: string | null): string | null {
  if (!avatar) return null;

  // Keep external URLs untouched.
  if (/^https?:\/\//i.test(avatar)) return avatar;

  // Convert absolute project paths (e.g. /avatars/x.jpg) to BASE_URL-aware paths.
  const normalizedBase = baseUrl.endsWith("/") ? baseUrl.slice(0, -1) : baseUrl;
  const normalizedAvatar = avatar.startsWith("/") ? avatar.slice(1) : avatar;

  return `${normalizedBase}/${normalizedAvatar}`;
}

const avatarSrc = resolveAvatarSrc(group.avatar);

function formatMembers(n: number | null): string {
  if (!n) return "—";
  if (n >= 1000) return `${(n / 1000).toFixed(1).replace(".0", "")}k`;
  return String(n);
}
---

<a
  class="group-card"
  href={group.url ?? "#"}
  target="_blank"
  rel="noopener noreferrer"
  data-platform={group.platform}
>
  <div class="avatar">
    {
      avatarSrc ? (
        <img src={avatarSrc} alt={group.name} loading="lazy" />
      ) : (
        <span class="avatar-fallback">{initials}</span>
      )
    }
  </div>

  <div class="info">
    <div class="name-row">
      <h3>{group.name}</h3>
      {group.verified && <span class="badge verified" title="Verificat">✓</span>}
    </div>

    {group.username && <p class="username">@{group.username}</p>}

    {group.description && <p class="description">{group.description}</p>}

    <div class="meta">
      <span class="type">{group.type === "channel" ? "Canal" : "Grup"}</span>
      <span class="members">{formatMembers(group.members)} membri</span>
      <span class="platform">{group.platform}</span>
    </div>
  </div>
</a>

<style>
  .group-card {
    display: flex;
    gap: 1rem;
    padding: 1rem;
    border-radius: 12px;
    background: var(--card-bg, #16181c);
    border: 1px solid var(--card-border, #2a2d33);
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s ease, border-color 0.15s ease;
  }

  .group-card:hover {
    transform: translateY(-2px);
    border-color: var(--accent, #4a9eff);
  }

  .avatar {
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    overflow: hidden;
    background: #2a2d33;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .avatar-fallback {
    font-weight: 600;
    font-size: 1.1rem;
    color: #9aa0a8;
  }

  .info {
    flex: 1;
    min-width: 0;
  }

  .name-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .name-row h3 {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .badge.verified {
    color: #4a9eff;
    font-size: 0.85rem;
  }

  .username {
    margin: 0.15rem 0 0;
    font-size: 0.85rem;
    color: #8a8f98;
  }

  .description {
    margin: 0.4rem 0 0;
    font-size: 0.85rem;
    color: #b4b8c0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .meta {
    display: flex;
    gap: 0.6rem;
    margin-top: 0.6rem;
    font-size: 0.75rem;
    color: #6b7078;
  }

  .meta span {
    padding: 0.15rem 0.5rem;
    border-radius: 6px;
    background: #1f2227;
  }
</style>
